{
  "name": "assimp",
  "version": "6.0.4.0",
  "schemaVersion": 2,
  "kind": "DynamicLib",
  "description": "Open-Asset-Importer-Library (3D model loader)",
  "dependencies": {
    "zlib": "^1.3.0.0"
  },
  "options": {
    "shared": {
      "default": true,
      "allowed": [true, false],
      "description": "Build as shared library; set false for static"
    }
  },
  "build": {
    "system": "cmake",
    "configs": [
      "Debug",
      "Release",
      "RelWithDebInfo",
      "MinSizeRel"
    ],
    "configure": [
      "-DBUILD_SHARED_LIBS=${options.shared}",
      "-DASSIMP_BUILD_ASSIMP_TOOLS=OFF",
      "-DASSIMP_BUILD_SAMPLES=OFF",
      "-DASSIMP_BUILD_TESTS=OFF",
      "-DASSIMP_BUILD_DOCS=OFF",
      "-DASSIMP_BUILD_ZLIB=OFF",
      "-DASSIMP_INSTALL_PDB=OFF",
      "-DCMAKE_DEBUG_POSTFIX=d",
      "-DCMAKE_RELWITHDEBINFO_POSTFIX=rd",
      "-DCMAKE_MINSIZEREL_POSTFIX=msr"
    ],
    "installDir": "install"
  }
}
